#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────
#  ClearPanel CLI — unified command‑line interface
#  Usage:  clearpanel <command> [options]
#
#  Install to PATH:
#    chmod +x /opt/clearpanel/bin/clearpanel
#    ln -sf /opt/clearpanel/bin/clearpanel /usr/local/bin/clearpanel
# ─────────────────────────────────────────────────────────────────────

set -euo pipefail

INSTALL_DIR="/opt/clearpanel"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Use INSTALL_DIR if it exists, otherwise fall back to script location
if [ -d "$INSTALL_DIR" ]; then
    BASE="$INSTALL_DIR"
else
    BASE="$SCRIPT_DIR"
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# ─── Helpers ───────────────────────────────────────────────────────

banner() {
    echo -e "${CYAN}${BOLD}"
    echo "  ╔═══════════════════════════════╗"
    echo "  ║        ClearPanel CLI         ║"
    echo "  ╚═══════════════════════════════╝"
    echo -e "${NC}"
}

require_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo -e "${RED}Error: This command must be run as root (sudo clearpanel $1)${NC}"
        exit 1
    fi
}

get_version() {
    if [ -f "$BASE/backend/package.json" ]; then
        node -e "console.log(require('$BASE/backend/package.json').version)" 2>/dev/null || echo "unknown"
    else
        echo "unknown"
    fi
}

get_data_dir() {
    if [ -f "$BASE/backend/.env" ]; then
        grep -oP '^DATA_DIR=\K.*' "$BASE/backend/.env" 2>/dev/null || echo ""
    fi
}

# ─── Commands ──────────────────────────────────────────────────────

cmd_version() {
    local ver
    ver=$(get_version)
    echo -e "${GREEN}ClearPanel v${ver}${NC}"
    echo "Install: $BASE"
    echo "Data:    $(get_data_dir || echo 'not configured')"
}

cmd_status() {
    banner
    echo -e "${BOLD}Version:${NC}  $(get_version)"
    echo -e "${BOLD}Install:${NC}  $BASE"
    echo -e "${BOLD}Data:${NC}     $(get_data_dir || echo 'not configured')"
    echo ""

    # Service status
    if systemctl is-active --quiet clearpanel 2>/dev/null; then
        echo -e "${BOLD}Service:${NC}  ${GREEN}● running${NC}"
    else
        echo -e "${BOLD}Service:${NC}  ${RED}● stopped${NC}"
    fi

    # API health
    if curl -sf http://127.0.0.1:3334/api/auth/status >/dev/null 2>&1; then
        echo -e "${BOLD}API:${NC}      ${GREEN}● reachable${NC}"
    else
        echo -e "${BOLD}API:${NC}      ${RED}● unreachable${NC}"
    fi

    # License status
    local license
    license=$(grep -oP '^LICENSE_KEY=\K.*' "$BASE/backend/.env" 2>/dev/null || echo "")
    if [ -n "$license" ]; then
        echo -e "${BOLD}License:${NC}  ${GREEN}configured${NC} (${license:0:4}****)"
    else
        echo -e "${BOLD}License:${NC}  ${YELLOW}not activated${NC}"
    fi
    echo ""
}

cmd_update() {
    require_root "update"
    banner
    echo -e "${BLUE}Checking for updates...${NC}"

    local CURRENT_VER
    CURRENT_VER=$(get_version)
    echo -e "Current version: ${BOLD}v${CURRENT_VER}${NC}"

    local LICENSE_KEY
    LICENSE_KEY=$(grep -oP '^LICENSE_KEY=\K.*' "$BASE/backend/.env" 2>/dev/null || echo "")
    local DATA_DIR
    DATA_DIR=$(get_data_dir)

    # ── Step 1: Check with license server (or fall back to git) ──
    local USE_RELEASE=false
    local DOWNLOAD_URL=""
    local LATEST_VER=""

    if [ -n "$LICENSE_KEY" ]; then
        echo -e "${BLUE}Checking license server for updates...${NC}"
        local API_RESP
        API_RESP=$(curl -sf "https://api.clearpanel.io/v1/releases/latest?license=${LICENSE_KEY}&current=${CURRENT_VER}" 2>/dev/null || echo "")

        if [ -n "$API_RESP" ]; then
            LATEST_VER=$(echo "$API_RESP" | node -e "const d=require('fs').readFileSync('/dev/stdin','utf8');const j=JSON.parse(d);console.log(j.version||'')" 2>/dev/null || echo "")
            DOWNLOAD_URL=$(echo "$API_RESP" | node -e "const d=require('fs').readFileSync('/dev/stdin','utf8');const j=JSON.parse(d);console.log(j.url||'')" 2>/dev/null || echo "")
            local AVAILABLE
            AVAILABLE=$(echo "$API_RESP" | node -e "const d=require('fs').readFileSync('/dev/stdin','utf8');const j=JSON.parse(d);console.log(j.available?'true':'false')" 2>/dev/null || echo "false")

            if [ "$AVAILABLE" = "true" ] && [ -n "$DOWNLOAD_URL" ]; then
                USE_RELEASE=true
                echo -e "${GREEN}Update available: v${LATEST_VER}${NC}"
            elif [ "$AVAILABLE" = "false" ]; then
                echo -e "${GREEN}Already on the latest version (v${CURRENT_VER})${NC}"
                exit 0
            fi
        else
            echo -e "${YELLOW}License server unreachable — falling back to git pull${NC}"
        fi
    fi

    # ── Step 2: Pre‑update backup ──
    echo -e "\n${BLUE}Creating pre-update backup...${NC}"
    local BACKUP_DIR="$BASE/backups/pre-update_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$BACKUP_DIR"

    # Backup .env
    [ -f "$BASE/backend/.env" ] && cp "$BASE/backend/.env" "$BACKUP_DIR/env.bak"

    # Backup data dir
    if [ -n "$DATA_DIR" ] && [ -d "$DATA_DIR" ]; then
        mkdir -p "$BACKUP_DIR/data"
        cp -a "$DATA_DIR"/. "$BACKUP_DIR/data/" 2>/dev/null || true
    fi

    # Backup bootstrap data
    if [ -d "$BASE/data" ]; then
        mkdir -p "$BACKUP_DIR/bootstrap"
        cp -a "$BASE/data"/. "$BACKUP_DIR/bootstrap/" 2>/dev/null || true
    fi

    # Backup mail state
    for mdir in /etc/clearpanel/mail "$BASE/backend/mail-state"; do
        if [ -d "$mdir" ]; then
            mkdir -p "$BACKUP_DIR/mail-state"
            cp -a "$mdir"/. "$BACKUP_DIR/mail-state/" 2>/dev/null || true
            break
        fi
    done

    echo -e "${GREEN}Backup saved to ${BACKUP_DIR}${NC}"

    # Prune old backups (keep last 5)
    local COUNT
    COUNT=$(ls -dt "$BASE/backups"/pre-update_* 2>/dev/null | tail -n +6 | wc -l)
    if [ "$COUNT" -gt 0 ]; then
        ls -dt "$BASE/backups"/pre-update_* | tail -n +6 | xargs rm -rf
        echo "Pruned $COUNT old backup(s)"
    fi

    # ── Step 3: Download / Pull ──
    if [ "$USE_RELEASE" = true ]; then
        echo -e "\n${BLUE}Downloading release v${LATEST_VER}...${NC}"
        local TMP_ARCHIVE="/tmp/clearpanel-${LATEST_VER}.tar.gz"
        curl -fSL "$DOWNLOAD_URL" -o "$TMP_ARCHIVE"

        # Verify signature if signing key exists
        if [ -f "$BASE/release/clearpanel-release.pub" ]; then
            if [ -f "${TMP_ARCHIVE}.sig" ]; then
                echo "Verifying release signature..."
                openssl dgst -sha256 -verify "$BASE/release/clearpanel-release.pub" -signature "${TMP_ARCHIVE}.sig" "$TMP_ARCHIVE" || {
                    echo -e "${RED}Signature verification FAILED — aborting update${NC}"
                    exit 1
                }
            fi
        fi

        echo "Extracting..."
        # Extract, overwriting only app code (never data dirs)
        tar -xzf "$TMP_ARCHIVE" -C "$BASE" \
            --exclude='backend/.env' \
            --exclude='data/' \
            --exclude='backups/' \
            --exclude='backend/mail-state/' \
            --exclude='backend/mail-policies/'

        rm -f "$TMP_ARCHIVE" "${TMP_ARCHIVE}.sig"
    else
        echo -e "\n${BLUE}Pulling latest from git...${NC}"
        cd "$BASE"
        git pull origin main
    fi

    # ── Step 4: Rebuild ──
    echo -e "\n${BLUE}Installing dependencies & building...${NC}"

    cd "$BASE/backend"
    npm install --legacy-peer-deps 2>&1 | tail -1
    npm run build 2>&1 | tail -1

    cd "$BASE/frontend"
    npm install --legacy-peer-deps 2>&1 | tail -1
    npm run build 2>&1 | tail -1

    # ── Step 5: Run any system‑level update scripts ──
    if [ -f "$BASE/release/post-update.sh" ]; then
        echo -e "\n${BLUE}Running post-update scripts...${NC}"
        bash "$BASE/release/post-update.sh"
    fi

    # ── Step 6: Restart service ──
    echo -e "\n${BLUE}Restarting ClearPanel service...${NC}"
    systemctl restart clearpanel

    # Wait for API ready
    for i in $(seq 1 15); do
        if curl -sf http://127.0.0.1:3334/api/auth/status >/dev/null 2>&1; then
            break
        fi
        sleep 2
    done

    local NEW_VER
    NEW_VER=$(get_version)

    if curl -sf http://127.0.0.1:3334/api/auth/status >/dev/null 2>&1; then
        echo -e "\n${GREEN}${BOLD}✓ Update complete! ClearPanel v${NEW_VER} is running.${NC}"
    else
        echo -e "\n${RED}Warning: API is not responding after restart.${NC}"
        echo -e "Check logs: ${YELLOW}journalctl -u clearpanel -n 50${NC}"
        echo -e "Restore backup: ${YELLOW}clearpanel restore${NC}"
    fi
}

cmd_backup() {
    require_root "backup"
    if [ -f "$BASE/backup-restore.sh" ]; then
        bash "$BASE/backup-restore.sh" backup
    else
        echo -e "${RED}backup-restore.sh not found at $BASE${NC}"
        exit 1
    fi
}

cmd_restore() {
    require_root "restore"
    if [ -f "$BASE/backup-restore.sh" ]; then
        bash "$BASE/backup-restore.sh" restore
    else
        echo -e "${RED}backup-restore.sh not found at $BASE${NC}"
        exit 1
    fi
}

cmd_license() {
    local subcmd="${1:-status}"
    case "$subcmd" in
        status)
            local key
            key=$(grep -oP '^LICENSE_KEY=\K.*' "$BASE/backend/.env" 2>/dev/null || echo "")
            if [ -n "$key" ]; then
                echo -e "${GREEN}License key: ${key:0:4}****${key: -4}${NC}"
            else
                echo -e "${YELLOW}No license key configured${NC}"
                echo "Activate: clearpanel license activate <KEY>"
            fi
            ;;
        activate)
            require_root "license activate"
            local key="${2:-}"
            if [ -z "$key" ]; then
                echo -e "${RED}Usage: clearpanel license activate <LICENSE_KEY>${NC}"
                exit 1
            fi
            # Write to .env
            local ENV_FILE="$BASE/backend/.env"
            if grep -q '^LICENSE_KEY=' "$ENV_FILE" 2>/dev/null; then
                sed -i "s|^LICENSE_KEY=.*|LICENSE_KEY=$key|" "$ENV_FILE"
            else
                echo "LICENSE_KEY=$key" >> "$ENV_FILE"
            fi
            echo -e "${GREEN}License key saved. Restart the panel to activate: sudo systemctl restart clearpanel${NC}"
            ;;
        deactivate)
            require_root "license deactivate"
            local ENV_FILE="$BASE/backend/.env"
            sed -i '/^LICENSE_KEY=/d' "$ENV_FILE"
            echo -e "${YELLOW}License key removed. Restart the panel: sudo systemctl restart clearpanel${NC}"
            ;;
        *)
            echo "Usage: clearpanel license [status|activate <KEY>|deactivate]"
            ;;
    esac
}

cmd_logs() {
    journalctl -u clearpanel -n "${1:-50}" --no-pager
}

cmd_restart() {
    require_root "restart"
    echo -e "${BLUE}Restarting ClearPanel...${NC}"
    systemctl restart clearpanel
    sleep 2
    if systemctl is-active --quiet clearpanel; then
        echo -e "${GREEN}✓ ClearPanel restarted successfully${NC}"
    else
        echo -e "${RED}✗ ClearPanel failed to start. Check: clearpanel logs${NC}"
    fi
}

cmd_help() {
    banner
    echo -e "${BOLD}Usage:${NC}  clearpanel <command> [options]"
    echo ""
    echo -e "${BOLD}Commands:${NC}"
    echo "  status              Show panel status, version, and license info"
    echo "  version             Show version number"
    echo "  update              Update ClearPanel to the latest version"
    echo "  backup              Create a full backup"
    echo "  restore             Restore from a backup"
    echo "  license [sub]       Manage license (status|activate <KEY>|deactivate)"
    echo "  logs [N]            Show last N log lines (default: 50)"
    echo "  restart             Restart the ClearPanel service"
    echo "  help                Show this help message"
    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo "  sudo clearpanel update"
    echo "  sudo clearpanel license activate ABCD-1234-EFGH-5678"
    echo "  clearpanel status"
    echo "  clearpanel logs 100"
    echo ""
}

# ─── Main dispatch ─────────────────────────────────────────────────

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    status)     cmd_status ;;
    version)    cmd_version ;;
    update)     cmd_update ;;
    backup)     cmd_backup ;;
    restore)    cmd_restore ;;
    license)    cmd_license "$@" ;;
    logs)       cmd_logs "$@" ;;
    restart)    cmd_restart ;;
    help|--help|-h)  cmd_help ;;
    *)
        echo -e "${RED}Unknown command: $COMMAND${NC}"
        cmd_help
        exit 1
        ;;
esac
