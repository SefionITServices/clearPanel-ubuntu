# Server Configuration
PORT=3000
SESSION_SECRET=change-this-to-a-random-secure-string
MAIL_MODE=dev

# Admin Credentials (set automatically by the Setup Wizard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# File Manager Settings
# ROOT_PATH = where user home directories live (website files)
ROOT_PATH=/home
# DATA_DIR = where panel data files are stored (domains.json, dns.json, etc.)
#            Set by setup wizard to /home/<username>/etc/clearpanel/
# DATA_DIR=/home/yourusername/etc/clearpanel
ALLOWED_EXTENSIONS=*
MAX_FILE_SIZE=104857600
