# Server Configuration
PORT=3000
SESSION_SECRET=change-this-to-a-random-secure-string

# Admin Credentials (set automatically by the Setup Wizard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# File Manager Settings
# ROOT_PATH is set automatically by install.sh — defaults to /opt/clearpanel/data
ROOT_PATH=/opt/clearpanel/data
ALLOWED_EXTENSIONS=*
MAX_FILE_SIZE=104857600
