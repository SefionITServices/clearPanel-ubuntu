# Server Configuration
PORT=3000
SESSION_SECRET=change-this-to-a-random-secure-string

# Admin Credentials (set automatically by the Setup Wizard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# File Manager Settings
# ROOT_PATH = where user home directories live (website files)
ROOT_PATH=/home
# DATA_DIR = where internal panel data is stored (auto-detected from install location)
# DATA_DIR=/opt/clearpanel/data
ALLOWED_EXTENSIONS=*
MAX_FILE_SIZE=104857600
